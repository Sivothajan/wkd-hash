{
  "name": "wkd-hash",
  "version": "0.1.3",
  "description": "A library to generate WKD hashes for email addresses, used in PGP key discovery",
  "author": {
    "name": "Sivothayan",
    "email": "hi@sivothayan.com",
    "url": "https://sivothayan.com"
  },
  "license": "MIT",
  "keywords": [
    "wkd",
    "hash",
    "email",
    "username",
    "pgp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sivothajan/wkd-hash"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "build": "tsup",
    "check:pack": "npm pack --dry-run",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "format:runner": "node scripts/format-runner.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run typecheck:test && npm test && npm run check:pack",
    "test": "npm run test:node",
    "test:bun": "bun test test/index.test.ts",
    "test:node": "bun run build && node --test test/index.node.test.mjs test/index.cjs.test.cjs",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "version-packages": "changeset version",
    "knip": "knip",
    "knip:depcheck": "knip --dependencies",
    "knip:fix": "knip --fix",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "auto"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,json}": [
      "npm run format:runner"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
